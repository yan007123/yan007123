{
  "林默": {
    "性别": "男",
    "行为风格": "冷静、果断、善于观察和推理，行动力强，面对危机时能迅速做出判断。在调查案件时心思缜密，不放过任何细节。",
    "语言风格": "言简意赅，逻辑清晰，偶尔带有讽刺或反问。在询问或陈述事实时语气冷静、客观。",
    "外貌描述": "面容冷峻，眼神锐利如鹰，身材挺拔，常穿深色便装，给人一种干练且难以接近的感觉。",
    "核心事件": "作为刑警队长，负责调查一系列离奇案件，在追查过程中逐渐发现案件背后隐藏的巨大阴谋，并与幕后黑手展开智力和武力的较量。",
    "一句话概括人物": "冷静果断的刑警队长，拥有极强的观察力和推理能力，是正义的坚定捍卫者。",
    "角色": "主角"
  },
  "苏婉清": {
    "性别": "女",
    "行为风格": "温柔善良，富有同情心，但在关键时刻展现出坚韧和勇敢的一面。作为医生，尽职尽责，对生命充满敬畏。",
    "语言风格": "语气温和，富有耐心，善于倾听和安慰他人。在专业领域表述清晰、准确。",
    "外貌描述": "气质温婉，五官清秀，长发常简单束起，身穿白大褂时显得专业而可靠，眼神中常带着关切。",
    "核心事件": "作为法医，协助林默进行案件调查，提供关键的技术支持。在调查过程中，她的专业知识和善良本性多次帮助团队突破困境，并逐渐与林默建立起深厚的信任与默契。",
    "一句话概括人物": "温柔坚韧的法医，专业能力出色，是主角可靠的搭档与支持者。",
    "角色": "女主"
  },
  "赵天雄": {
    "性别": "男",
    "行为风格": "老谋深算，城府极深，表面上是成功的企业家，背地里却操纵着庞大的犯罪网络。行事谨慎，手段狠辣，为达目的不择手段。",
    "语言风格": "说话慢条斯理，看似平和却暗藏机锋，善于用言语诱导和威胁他人，偶尔会流露出傲慢与残忍。",
    "外貌描述": "中年男子，衣着考究，发型一丝不苟，面容看似和善，但眼神深处藏着阴鸷与算计。",
    "核心事件": "是系列案件背后的真正主谋，利用其商业帝国作为掩护，进行非法交易。与林默多次交锋，是主角面临的最大对手。",
    "一句话概括人物": "城府极深的幕后黑手，表面光鲜，实则冷酷残忍，是故事的主要矛盾源头。",
    "角色": "反派"
  },
  "陈浩": {
    "性别": "男",
    "行为风格": "热血冲动，正义感强，是林默的得力下属。有时因急躁而犯错，但学习能力强，对林默十分敬重和忠诚。",
    "语言风格": "直率，有时略显毛躁，充满干劲。对不公之事会直接表达愤怒，对上级和同事坦诚。",
    "外貌描述": "年轻，身材结实，短发，常带着一股不服输的劲头，眼神明亮有神。",
    "核心事件": "跟随林默参与案件调查，在实战中不断成长，从最初的莽撞逐渐变得沉稳，成为团队中不可或缺的力量。",
    "一句话概括人物": "热血忠诚的年轻刑警，是主角的得力助手，在历练中不断成长。",
    "角色": "配角"
  },
